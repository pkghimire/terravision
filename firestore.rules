rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: content
    // Document ID: main
    // Fields:
    //   - theme: map (required)
    //   - home: map (required)
    //   - about: map (required)
    //   - services: list (required)
    //   - blog: list (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "payas4goog@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidContent(data) {
      return data.keys().hasAll(['theme', 'home', 'about', 'services', 'blog']) &&
             data.theme is map &&
             data.home is map &&
             data.about is map &&
             data.services is list &&
             data.blog is list;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /content/main {
      allow read: if true;
      allow write: if isAdmin() && isValidContent(request.resource.data);
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
